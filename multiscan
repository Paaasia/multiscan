<!DOCTYPE html>
<html lang="fi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NexLink Advanced UDS Scanner</title>
    <style>
        body { font-family: -apple-system, sans-serif; background: #111827; color: #f3f4f6; padding: 15px; margin: 0; }
        .container { max-width: 600px; margin: auto; }
        .card { background: #1f2937; padding: 15px; border-radius: 12px; border: 1px solid #374151; margin-bottom: 12px; }
        .label { color: #9ca3af; font-size: 0.75rem; text-transform: uppercase; font-weight: bold; margin-bottom: 6px; }
        
        button { width: 100%; padding: 14px; color: white; border: none; border-radius: 8px; font-weight: bold; cursor: pointer; margin-bottom: 8px; transition: 0.2s; }
        #connectBtn { background: #2563eb; }
        #connectBtn:hover { background: #1d4ed8; }
        .action-btn { background: #059669; width: 48%; display: inline-block; }
        
        input, select { width: 100%; padding: 10px; margin-bottom: 10px; background: #374151; border: 1px solid #4b5563; color: white; border-radius: 6px; box-sizing: border-box; }
        
        .row { display: flex; justify-content: space-between; gap: 10px; }
        
        #log { margin-top: 10px; font-family: 'Courier New', monospace; font-size: 0.75rem; color: #34d399; background: #000; padding: 12px; border-radius: 8px; height: 250px; overflow-y: auto; border: 1px solid #065f46; white-space: pre-wrap;}
        .log-tx { color: #60a5fa; }
        .log-rx { color: #fcd34d; }
        .log-info { color: #9ca3af; }
    </style>
</head>
<body>

<div class="container">
    <h2 style="text-align:center; color: #60a5fa; margin: 10px 0;">NexLink Multi-Module Scanner</h2>
    <p style="text-align:center; font-size:0.8rem; color:#9ca3af;">Lue vikakoodit asettamalla oikea CAN-osoite (Header).</p>
    
    <button id="connectBtn">1. YHDISTÄ LUKIJAAN</button>

    <div class="card">
        <div class="label">Kohteen valinta (CAN Header)</div>
        <select id="presetSelect">
            <option value="7DF">Standardi OBD2 (Moottori, 7DF)</option>
            <option value="7C0">Esimerkki: Ford/Volvo ABS (7C0)</option>
            <option value="720">Esimerkki: VAG Mittaristo (720)</option>
            <option value="CUSTOM">Mukautettu osoite...</option>
        </select>
        <input type="text" id="customHeader" placeholder="Esim. 7A0" style="display:none;" maxlength="3">

        <div class="label">Komento (Hex)</div>
        <select id="cmdSelect">
            <option value="03">OBD2: Lue vahvistetut koodit (03)</option>
            <option value="19020D">UDS: Lue koodit (19 02 0D)</option>
            <option value="22F190">UDS: Lue VIN (22 F1 90)</option>
            <option value="CUSTOM">Mukautettu komento...</option>
        </select>
        <input type="text" id="customCmd" placeholder="Esim. 19020B" style="display:none;">

        <div class="row" style="margin-top: 10px;">
            <button class="action-btn" id="sendBtn" style="background:#0284c7;">LÄHETÄ KOMENTO</button>
            <button class="action-btn" id="clearLogBtn" style="background:#4b5563;">TYHJENNÄ LOKI</button>
        </div>
    </div>

    <div id="log"><span class="log-info">Odottaa yhdistämistä...</span><br></div>
</div>

<script>
    let device, charWrite, charRead;
    const decoder = new TextDecoder();
    const encoder = new TextEncoder();
    let currentBuffer = "";

    const logBox = document.getElementById('log');
    const log = (msg, type = 'info') => { 
        let colorClass = type === 'tx' ? 'log-tx' : (type === 'rx' ? 'log-rx' : 'log-info');
        let prefix = type === 'tx' ? 'Lähetetty: ' : (type === 'rx' ? 'Vastaus:   ' : '');
        logBox.innerHTML += `<span class="${colorClass}">${prefix}${msg}</span><br>`; 
        logBox.scrollTop = logBox.scrollHeight;
    };

    // UI Logiikka
    document.getElementById('presetSelect').addEventListener('change', (e) => {
        document.getElementById('customHeader').style.display = e.target.value === 'CUSTOM' ? 'block' : 'none';
    });
    document.getElementById('cmdSelect').addEventListener('change', (e) => {
        document.getElementById('customCmd').style.display = e.target.value === 'CUSTOM' ? 'block' : 'none';
    });
    document.getElementById('clearLogBtn').addEventListener('click', () => logBox.innerHTML = '');

    // Bluetooth Yhteys
    document.getElementById('connectBtn').addEventListener('click', async () => {
        try {
            log("Etsitään laitteita...", "info");
            device = await navigator.bluetooth.requestDevice({
                filters: [{ namePrefix: 'NEXAS' }, { namePrefix: 'NexLink' }, { namePrefix: 'OBD' }],
                optionalServices: ['0000fff0-0000-1000-8000-00805f9b34fb']
            });
            const gatt = await device.gatt.connect();
            const service = await gatt.getPrimaryService('0000fff0-0000-1000-8000-00805f9b34fb');
            const chars = await service.getCharacteristics();
            for (const c of chars) {
                if (c.properties.write || c.properties.writeWithoutResponse) charWrite = c;
                if (c.properties.notify) charRead = c;
            }
            await charRead.startNotifications();
            charRead.addEventListener('characteristicvaluechanged', handleResponse);
            
            log("Yhdistetty! Alustetaan lukija...", "info");
            await initELM327();
            
        } catch (e) { log("Virhe: " + e.message, "info"); }
    });

    function handleResponse(e) {
        currentBuffer += decoder.decode(e.target.value);
        if (currentBuffer.includes(">")) {
            let cleanRes = currentBuffer.replace(/>/g, '').trim();
            if (cleanRes) {
                // Poistetaan kaiutetut komennot selkeyden vuoksi
                let lines = cleanRes.split('\r').filter(l => l.trim() !== '');
                lines.forEach(line => log(line, "rx"));
            }
            currentBuffer = "";
        }
    }

    async function sendCommand(cmd, delay = 500) {
        if (!charWrite) return;
        log(cmd, "tx");
        await charWrite.writeValueWithoutResponse(encoder.encode(cmd + '\r'));
        await new Promise(r => setTimeout(r, delay)); 
    }

    async function initELM327() {
        await sendCommand("ATZ", 1000);   // Nollaus
        await sendCommand("ATE0");        // Kaiutus pois päältä
        await sendCommand("ATL0");        // Rivinvaihdot pois
        await sendCommand("ATH1");        // Näytä CAN-osoitteet vastauksissa (tärkeä!)
        await sendCommand("ATSP6");       // Pakota CAN-protokolla (yleisin nykyautoissa)
        log("Alustus valmis. Voit nyt lähettää komentoja.", "info");
    }

    // Komennon lähetys
    document.getElementById('sendBtn').addEventListener('click', async () => {
        if (!charWrite) {
            alert("Yhdistä ensin lukijaan!");
            return;
        }

        let header = document.getElementById('presetSelect').value;
        if (header === 'CUSTOM') header = document.getElementById('customHeader').value.trim();
        
        let cmd = document.getElementById('cmdSelect').value;
        if (cmd === 'CUSTOM') cmd = document.getElementById('customCmd').value.trim();

        if (!header || !cmd) {
            alert("Tarkista osoite ja komento.");
            return;
        }

        log("--- Uusi kysely ---", "info");
        
        // Asetetaan osoite
        if (header !== "7DF") {
            await sendCommand("AT SH " + header); // Aseta CAN Header
            await sendCommand("ATCRA " + (parseInt(header, 16) + 8).toString(16).toUpperCase()); // Aseta vastaanotto-osoite (yleensä lähetys + 8)
        } else {
            await sendCommand("ATZ"); // Resetoidaan vakiotilaan
            await sendCommand("ATE0");
            await sendCommand("ATH1");
        }

        // Lähetetään itse komento
        await sendCommand(cmd, 2000);
    });
</script>
</body>
</html>
